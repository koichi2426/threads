# =============================================================================
# Threads API 基本操作キット — 環境変数テンプレート
# =============================================================================
#
# 使い方:
#   1. このファイルをコピーして `.env` を作る
#        cp .env.example .env
#   2. 必須の `THREADS_ACCESS_TOKEN` に実トークンを貼る
#   3. `threads-kit` または `python fetch_threads.py` を実行する
#
# `.env` は .gitignore 済みです。トークンや秘密情報を Git にコミットしないでください。
#
# -----------------------------------------------------------------------------

# 必須: Meta for Developers で発行したユーザーアクセストークン
#        （threads_basic など、用途に合うスコープ付き）
THREADS_ACCESS_TOKEN=

# 任意: Graph API のベース URL（公式の既定と異なるエンドポイントを試すときだけ）
#        未設定または空なら https://graph.threads.net/v1.0 が使われます。
# THREADS_GRAPH_BASE_URL=https://graph.threads.net/v1.0
